  \centering
  \begin{subfigure}[t]{0.49\textwidth}
    \includegraphics[width=\linewidth]{\figdir/final_bdt_nom.pdf}
    \caption{nominal (all-z)}
  \end{subfigure}
  \begin{subfigure}[t]{0.49\textwidth}
    \includegraphics[width=\linewidth]{\figdir/final_bdt_mask_common_harddead_zlt2.pdf}
    \caption{mask\_common\_harddead\_zlt2 (+4.37\%)}
  \end{subfigure}\\[2pt]
  \begin{subfigure}[t]{0.49\textwidth}
    \includegraphics[width=\linewidth]{\figdir/final_bdt_mask_tight_harddead_zlt2.pdf}
    \caption{mask\_tight\_harddead\_zlt2 (+4.87\%)}
  \end{subfigure}
  \begin{subfigure}[t]{0.49\textwidth}
    \includegraphics[width=\linewidth]{\figdir/final_bdt_mask_or_harddead_zlt2.pdf}
    \caption{mask\_or\_harddead\_zlt2 (+7.17\%, heaviest)}
